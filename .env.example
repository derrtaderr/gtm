# Magnetiz GTM Agent System V2
# Copy this to .env and fill in your values

# Claude Agent SDK
ANTHROPIC_API_KEY=

# Supabase PostgreSQL
DATABASE_URL=

# Clay (bidirectional webhook integration)
# CLAY_WEBHOOK_URL is the unique webhook URL for your Clay enrichment table.
# Get it from Clay UI: + Add → Webhooks → Monitor webhook → Copy URL.
# Format: https://api.clay.com/v3/sources/webhook/pull-in-data-from-a-webhook-{UUID}
CLAY_WEBHOOK_URL=
# Optional: token Clay sends as Authorization header on its callback to /webhook/clay
CLAY_CALLBACK_SECRET=
# Optional: token we send as Authorization header when POSTing to Clay's webhook
CLAY_WEBHOOK_AUTH_TOKEN=

# Proxycurl ($49/mo plan - 500 credits/month)
PROXYCURL_API_KEY=

# GoExtrovert
GOEXTROVERT_API_KEY=
GOEXTROVERT_CAMPAIGN_ID=
GOEXTROVERT_LIST_ID=

# LinkedIn Marketing API
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=

# RB2B Webhook
RB2B_WEBHOOK_SECRET=

# Server
PORT=3000
